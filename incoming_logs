        if st.button("Start Batch Analysis"):
            # Load the new file
            new_df = pd.read_csv(os.path.join(log_folder, selected_file))
            
            # Predict for the whole file
            # We assume the file has the 30 columns the model needs
            X_batch = new_df.iloc[:, :30] 
            predictions = model.predict(X_batch)
            new_df['Security_Status'] = ["🚩 FRAUD" if p == 1 else "✅ SAFE" for p in predictions]
            
